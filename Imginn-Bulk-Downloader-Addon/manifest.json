{
  "manifest_version": 3,
  "name": "Imginn Bulk Downloader",
  "version": "0.1",

  "description": "From a list of Imginn URLs, prompts and downloads high-resolution version of the images from each page.",
  "icons": {
    "32": "icons/icon32.png",
    "64": "icons/icon64.png"
  },

  "homepage_url": "https://github.com/SubstituteDoll/Imginn-Bulk-Downloader",

  "action": {
    "default_popup": "foreground/app.html"
  },

  "background": {
    "scripts": ["background/background.js"]
  },

  "permissions": ["tabs", "storage"],

  "host_permissions": [
    "*://imginn.com/*",
    "*://*.imginn.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://imginn.com/*", "*://*.imginn.com/*"],
      "js": ["content/post_date.js"],
      "run_at": "document_idle"
    }
  ]
}